# Managed by Ansible - PPS + GPS (gpsd SHM) for Flock You
# pool 0.pool.ntp.org iburst   # Uncomment if Pi has internet
driftfile /var/lib/chrony/drift
makestep 0.1 3

# GPS coarse time from gpsd shared memory
refclock SHM 0 offset 0.0 delay 0.2 refid GPS noselect
# PPS precise (GPIO18)
refclock PPS /dev/pps0 lock GPS refid PPS
